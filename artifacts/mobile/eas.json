{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://campus-connect-app.replit.app/api"
      }
    },
    "production": {
      "channel": "production",
      "credentialsSource": "remote",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://campus-connect-app.replit.app/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
