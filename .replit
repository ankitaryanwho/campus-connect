modules = ["web", "bash", "nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=8080 node artifacts/api-server/dist/index.cjs"]
build = ["bash", "-c", "pnpm --filter @workspace/api-server run build && BASE_PATH=/admin/ PORT=4000 pnpm --filter @workspace/admin run build"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push OTA Update"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/caddy: Reverse Proxy"

[[workflows.workflow]]
name = "Push OTA Update"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EAS_NO_VCS=1 pnpm --filter @workspace/mobile exec eas update --channel preview --non-interactive --message \"Replit update\" && EAS_NO_VCS=1 pnpm --filter @workspace/mobile exec eas update --channel production --non-interactive --message \"Replit update\""

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "artifacts/caddy: Reverse Proxy"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "caddy run --config /home/runner/workspace/Caddyfile --adapter caddyfile"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["eas-cli"]

[userenv]

[userenv.shared]
VITE_API_URL = "https://campus-connect-app.replit.app"
EXPO_PUBLIC_API_URL = "https://campus-connect-app.replit.app/api"

[userenv.production]
NEON_SOURCE_URL = "postgresql://neondb_owner:npg_2rRPlbeHc1Dt@ep-divine-sky-a4dm30t7.us-east-1.aws.neon.tech/neondb?sslmode=require"
NEON_IMPORT_SECRET = "cc-import-2024-secret"

[userenv.development]
PROD_DATABASE_URL = "postgresql://neondb_owner:npg_J6z5ZxCpmley@ep-morning-pine-anasye4r-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
