modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Push OTA Update"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev & PORT=23744 BASE_PATH=/admin/ pnpm --filter @workspace/admin run dev"
waitForPort = 23744

[[workflows.workflow]]
name = "Push OTA Update"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "EAS_NO_VCS=1 pnpm --filter @workspace/mobile exec eas update --channel preview --non-interactive --message \"Replit update\" && EAS_NO_VCS=1 pnpm --filter @workspace/mobile exec eas update --channel production --non-interactive --message \"Replit update\""

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["resend:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
FIREBASE_SERVICE_ACCOUNT_JSON = ""
